    "@hexclave/next": "workspace:*",
    "@hexclave/shared": "workspace:*",
    "@hexclave/ui": "workspace:*",
    "next": "15.5.19",
    "next-themes": "^0.4.3",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "react-icons": "^5.3.0"
  },
  "devDependencies": {
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "rimraf": "^5.0.10",
    "tailwindcss": "^3.4.14"
  },
  "packageManager": "pnpm@11.5.0"
